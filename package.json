{
  "name": "buildfoce_be",
  "version": "0.0.0",
  "private": "true",
  "main": "dist/server.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node server.ts",
    "dev:simple": "nodemon --exec ts-node server.ts",
    "dev:watch": "nodemon --watch src --ext ts,js --exec ts-node server.ts",
    "dev:quick": "node dev.js",
    "test": "jest --runInBand",
    "test:nocolor": "set \"FORCE_COLOR=0\" && set \"NO_COLOR=1\" && jest --runInBand --colors=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mm-cleanup": "jest --coverage --testPathPatterns src/schedulers/__tests__/matchmakingCleanup\\.scheduler\\.test\\.ts",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "test:integration": "jest --config jest.config.integration.ts",
    "test:integration:watch": "jest --config jest.config.integration.ts --watch"
  },
  "license": "MIT",
